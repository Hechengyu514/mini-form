{
  "id": "tpl-contact-form",
  "title": "联系我们",
  "settings": { "showSubmitButton": true, "showSerialNumber": false },
  "components": [
    { "id": "tpl-contact-1", "type": "input", "title": "姓名", "placeholder": "请输入您的姓名", "required": true, "validation": [{ "type": "required", "message": "请输入姓名" }] },
    { "id": "tpl-contact-2", "type": "input", "title": "邮箱", "placeholder": "请输入邮箱地址", "required": true, "validation": [{ "type": "required", "message": "请输入邮箱" }, { "type": "pattern", "pattern": "email", "message": "请输入有效的邮箱地址" }] },
    { "id": "tpl-contact-3", "type": "select", "title": "咨询类型", "placeholder": "请选择咨询类型", "required": true, "options": [{ "id": "tpl-c-opt-1", "label": "产品咨询", "value": "product" }, { "id": "tpl-c-opt-2", "label": "售后服务", "value": "support" }, { "id": "tpl-c-opt-3", "label": "商务合作", "value": "business" }, { "id": "tpl-c-opt-4", "label": "其他", "value": "other" }] },
    { "id": "tpl-contact-4", "type": "input", "title": "公司名称", "placeholder": "请输入公司名称（选填）", "required": false },
    { "id": "tpl-contact-5", "type": "input", "title": "联系电话", "placeholder": "请输入联系电话", "required": false, "validation": [{ "type": "pattern", "pattern": "phone", "message": "请输入有效的手机号" }] },
    { "id": "tpl-contact-6", "type": "textarea", "title": "留言内容", "placeholder": "请详细描述您的问题或需求...", "required": true, "validation": [{ "type": "required", "message": "请输入留言内容" }, { "type": "minLength", "value": 10, "message": "至少输入10个字符" }] },
    { "id": "tpl-contact-7", "type": "upload", "title": "附件", "placeholder": "上传相关截图或文件", "required": false, "props": { "maxCount": 3 } },
    { "id": "tpl-contact-submit", "type": "submit-button", "title": "提交留言", "props": { "btnType": "primary", "align": "center", "block": true, "size": "large" }, "meta": { "isDisplay": true, "skipValidation": true } }
  ]
}
